<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meet New People | Private Chat</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        
        body { background-color: #0d1117; color: white; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; overflow-x: hidden; }

        /* Background Animation */
        .bg-animate { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at 20% 30%, #4a148c 0%, transparent 40%), radial-gradient(circle at 80% 70%, #880e4f 0%, transparent 40%); opacity: 0.2; z-index: -1; filter: blur(60px); }

        .container { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.08); padding: 50px 30px; border-radius: 30px; text-align: center; max-width: 420px; width: 100%; box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6); position: relative; animation: fadeInContainer 1s ease-out; }

        /* User Profiles Grid */
        .profile-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 30px; animation: slideUp 1s ease-out; }
        .profile-card { position: relative; border-radius: 15px; overflow: hidden; border: 2px solid transparent; transition: all 0.3s ease; aspect-ratio: 1; }
        .profile-card:hover { border-color: #ec407a; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(236, 64, 122, 0.3); }
        .profile-card img { width: 100%; height: 100%; object-fit: cover; }
        
        /* Large Central Profile */
        .profile-large { position: relative; margin-bottom: 35px; animation: scaleIn 0.8s ease-out; }
        .profile-large img { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 4px solid #ec407a; box-shadow: 0 0 25px rgba(236, 64, 122, 0.6); }
        .online-dot { position: absolute; bottom: 8px; right: 145px; width: 18px; height: 18px; background: #00c853; border-radius: 50%; border: 3px solid #0d1117; animation: pulse 1.5s infinite; }

        /* Typography */
        .status-text { color: #00c853; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
        h1 { font-size: 28px; font-weight: 700; margin-bottom: 12px; line-height: 1.2; letter-spacing: -0.5px; }
        h1 span { color: #ec407a; }
        p { color: #a1a1a1; font-size: 15px; line-height: 1.6; margin-bottom: 40px; }

        /* Premium Button */
        .btn { display: inline-block; background: linear-gradient(90deg, #ec407a 0%, #d81b60 100%); color: white; text-decoration: none; padding: 20px 50px; border-radius: 50px; font-weight: 700; font-size: 18px; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s ease; box-shadow: 0 10px 25px rgba(236, 64, 122, 0.4); width: 100%; max-width: 320px; animation: bounceIn 1.2s ease-out; }
        .btn:hover { background: linear-gradient(90deg, #d81b60 0%, #ad1457 100%); transform: translateY(-3px); box-shadow: 0 15px 35px rgba(236, 64, 122, 0.6); }

        /* Trust Signals */
        .trust-info { margin-top: 30px; font-size: 12px; color: #616161; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .trust-info i { color: #fbc02d; }

        /* Animations */
        @keyframes fadeInContainer { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes scaleIn { from { opacity: 0; transform: scale(0.8); } to { opacity: 1; transform: scale(1); } }
        @keyframes bounceIn { 0%, 20%, 40%, 60%, 80%, 100% { animation-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1); } 0% { opacity: 0; transform: scale3d(0.3, 0.3, 0.3); } 20% { transform: scale3d(1.1, 1.1, 1.1); } 40% { transform: scale3d(0.9, 0.9, 0.9); } 60% { opacity: 1; transform: scale3d(1.03, 1.03, 1.03); } 80% { transform: scale3d(0.97, 0.97, 0.97); } 100% { opacity: 1; transform: scale3d(1, 1, 1); } }
        @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(0, 200, 83, 0.6); } 70% { box-shadow: 0 0 0 12px rgba(0, 200, 83, 0); } 100% { box-shadow: 0 0 0 0 rgba(0, 200, 83, 0); } }

        /* Responsive */
        @media (max-width: 480px) { h1 { font-size: 24px; } p { font-size: 14px; } .btn { font-size: 16px; padding: 18px 40px; } .online-dot { right: 120px; } }
    </style>
</head>
<body>
    <div class="bg-animate"></div>
    <div class="container">
        <div class="profile-large">
            <img src="https://i.pravatar.cc/150?u=anna12" alt="Main Profile">
            <div class="online-dot"></div>
        </div>

        <div class="status-text">Verified Members Only</div>
        
        <h1>Meet New <span>People</span> Nearby! 🌍</h1>
        <p>Private chat, video calls, and safe connections. Discover real people waiting to chat right now.</p>
        
        <div class="profile-grid">
            <div class="profile-card"><img src="https://i.pravatar.cc/150?u=maria5"></div>
            <div class="profile-card"><img src="https://i.pravatar.cc/150?u=sofia8"></div>
            <div class="profile-card"><img src="https://i.pravatar.cc/150?u=chloe2"></div>
        </div>
        
        <a href="https://my.mountaff.com/smartlink?key=146547" class="btn">Start Private Chat</a>
        
        <div class="trust-info">
            <span>🔒 100% Secure</span> | <span>✅ Real Profiles</span> | <span>🤫 Privacy Protected</span>
        </div>
    </div>
</body>
</html>
